<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Stage 1 Report Template -->
    <template id="report_sqa_stage1">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="oe_structure">
                            <div class="row">
                                <div class="col-12">
                                    <h2 class="text-center">Stage 1 - Initial Costing Report</h2>
                                    <hr/>
                                </div>
                            </div>
                            
                            <div class="row mt32">
                                <div class="col-6">
                                    <strong>Reference:</strong> <span t-field="doc.name"/><br/>
                                    <strong>Pre-Order Ref:</strong> <span t-field="doc.pre_order_ref"/><br/>
                                    <strong>Customer:</strong> <span t-field="doc.partner_id.name"/><br/>
                                    <strong>Status:</strong> 
                                    <span t-if="doc.state == 'draft'" class="text-muted">Draft</span>
                                    <span t-if="doc.state == 'checked'" class="text-success">Checked</span>
                                </div>
                                <div class="col-6">
                                    <div class="bg-light p-2 rounded">
                                        <strong>Grand Total Cost:</strong> 
                                        <span t-esc="'{:,.2f}'.format(doc.grand_total_cost)"/><br/>
                                        <strong>Grand Total Sales:</strong> 
                                        <span t-esc="'{:,.2f}'.format(doc.grand_total_sales)"/><br/>
                                        <strong class="text-success">Expected Profit:</strong> 
                                        <span t-esc="'{:,.2f}'.format(doc.grand_total_sales - doc.grand_total_cost)"/>
                                    </div>
                                </div>
                            </div>

                            <!-- BOM Lines with Components -->
                            <div class="row mt32">
                                <div class="col-12">
                                    <h4>BOM Lines with Components</h4>
                                    <t t-foreach="doc.sqa_stage1_line_ids" t-as="line">
                                        <div class="mt16">
                                            <table class="table table-sm table-bordered">
                                                <thead>
                                                    <tr class="bg-primary text-white">
                                                        <th colspan="4">FINISH PRODUCT</th>
                                                        <th class="text-end">TOTALS</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr>
                                                        <td colspan="3">
                                                            <strong>BOM/Product:</strong> <span t-field="line.bom_id.display_name"/>
                                                            <br/>
                                                            <strong>Quantity:</strong> <span t-esc="'{:,.2f}'.format(line.product_qty)"/>
                                                        </td>
                                                        <td class="text-end">
                                                            <strong>Total Cost Price:</strong><br/>
                                                            <span t-esc="'{:,.2f}'.format(line.total_cost)"/>
                                                        </td>
                                                        <td class="text-end">
                                                            <strong>Total Sales Price:</strong><br/>
                                                            <span t-esc="'{:,.2f}'.format(line.total_sales)"/>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                            
                                            <!-- Component Lines -->
                                            <table class="table table-sm table-bordered mt8">
                                                <thead>
                                                    <tr class="bg-light">
                                                        <th>Component</th>
                                                        <th class="text-end">Quantity</th>
                                                        <th class="text-end">Cost Price</th>
                                                        <th class="text-end">Sales Price</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <t t-if="line.sqa_stage1_bom_id">
                                                        <t t-foreach="line.sqa_stage1_bom_id.bom_line_ids" t-as="component">
                                                            <tr>
                                                                <td><span t-field="component.product_id.name"/></td>
                                                                <td class="text-end"><span t-esc="'{:,.2f}'.format(component.product_qty)"/></td>
                                                                <td class="text-end"><span t-esc="'{:,.2f}'.format(component.cost_price)"/></td>
                                                                <td class="text-end"><span t-esc="'{:,.2f}'.format(component.sales_price)"/></td>
                                                            </tr>
                                                        </t>
                                                    </t>
                                                    <t t-if="not line.sqa_stage1_bom_id or not line.sqa_stage1_bom_id.bom_line_ids">
                                                        <tr>
                                                            <td colspan="4" class="text-muted text-center">No components found for this BOM</td>
                                                        </tr>
                                                    </t>
                                                </tbody>
                                            </table>
                                        </div>
                                    </t>
                                </div>
                            </div>

                            <div class="row mt32">
                                <div class="col-12">
                                    <div class="alert alert-info">
                                        <strong>Note:</strong> This report shows the initial costing estimates from Stage 1.
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>


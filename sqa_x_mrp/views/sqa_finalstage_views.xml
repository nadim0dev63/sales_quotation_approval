<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action -->
    <record id="action_sqa_finalstage" model="ir.actions.act_window">
        <field name="name">Final Stage</field>
        <field name="res_model">sqa.finalstage</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Review all three stages and approve the best quotation.
            </p>
            <p>
                Select a Pre-Order Reference to load all three stage totals.
                Compare expected profits, select the best stage, and click Approve.
            </p>
        </field>
    </record>

    <!-- List View -->
    <record id="view_sqa_finalstage_list" model="ir.ui.view">
        <field name="name">sqa.finalstage.list</field>
        <field name="model">sqa.finalstage</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="pre_order_ref_id"/>
                <field name="partner_id"/>
                <field name="quotation_approval"/>
                <field name="state" widget="badge" decoration-success="state == 'approved'" decoration-muted="state == 'draft'"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_sqa_finalstage_form" model="ir.ui.view">
        <field name="name">sqa.finalstage.form</field>
        <field name="model">sqa.finalstage</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" string="Approve" type="object" class="btn-primary" invisible="state == 'approved'"/>
                    <field name="state" widget="badge"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="pre_order_ref_id" required="1"/>
                            <field name="partner_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="quotation_approval" required="1" invisible="state == 'approved'"/>
                        </group>
                    </group>

                    <!-- Stage Comparison Groups -->
                    <group string="Stage Comparison">
                        <group string="Stage 1 - Initial Costing">
                            <field name="stage1_grand_cost" string="Grand Total Cost"/>
                            <field name="stage1_grand_sales" string="Grand Total Sales"/>
                            <field name="stage1_expected_profit" string="Expected Profit" widget="monetary" decoration-danger="stage1_expected_profit &lt; 0" decoration-success="stage1_expected_profit &gt; 0"/>
                        </group>
                        <group string="Stage 2 - Partial Review">
                            <field name="stage2_grand_cost" string="Grand Total Cost"/>
                            <field name="stage2_grand_sales" string="Grand Total Sales"/>
                            <field name="stage2_expected_profit" string="Expected Profit" widget="monetary" decoration-danger="stage2_expected_profit &lt; 0" decoration-success="stage2_expected_profit &gt; 0"/>
                        </group>
                        <group string="Stage 3 - Final Costing">
                            <field name="stage3_grand_cost" string="Grand Total Cost"/>
                            <field name="stage3_grand_sales" string="Grand Total Sales"/>
                            <field name="stage3_expected_profit" string="Expected Profit" widget="monetary" decoration-danger="stage3_expected_profit &lt; 0" decoration-success="stage3_expected_profit &gt; 0"/>
                        </group>
                    </group>

                    <group string="Results" invisible="state != 'approved'">
                        <field name="sale_order_id" string="Sales Quotation"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
</odoo>